# ============================================================================
*.o
*.a
*.so
*.so.*
*.dylib
*.lib
*.dll
*.exe

# ============================================================================
# 可执行文件
# ============================================================================
/linuxhud
/test_drm
/test_plane
/test_plane2
build/bin/test_*

# ============================================================================
# 调试文件
# ============================================================================
*.dSYM/
*.pdb
*.ilk
*.exp
/core
/core.*
vgcore.*
massif.out.*
callgrind.out.*

# ============================================================================
# IDE 和编辑器文件
# ============================================================================
