.vscode/
*.code-workspace

# Visual Studio
*.sln
*.vcxproj
*.vcxproj.filters
*.vcxproj.user
*.suo
*.user
*.userosscache
*.sln.docstates

# JetBrains (CLion, IntelliJ)
.idea/
*.iml
*.iws
*.ipr
cmake-build-*/

# Eclipse
.cproject
.project
.settings/
.buildpath

# Vim
*.swp
*.swo
*~
tags
TAGS

# Emacs
*~
\#*\#
.#*
*.elc
auto-save-list
tramp

# Sublime Text
*.sublime-project
*.sublime-workspace

# Xcode
*.xcworkspace
*.xcuserdata
xcuserdata/

# ============================================================================
# 系统文件
# ============================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory

# ============================================================================
# 日志和临时文件
# ============================================================================
*.log
*.tmp
*.temp
*.bak
*.backup
*.orig
*.rej

# ============================================================================
# 测试和覆盖率
# ============================================================================
*.gcda
*.gcno
*.gcov
*.lcov
coverage/
htmlcov/
.coverage
.coverage.*
coverage.xml

# ============================================================================
# 打包文件
# ============================================================================
*.tar.gz
*.tar.bz2
*.tar.xz
*.zip
*.rar
*.7z
*.deb
*.rpm
*.msi
*.dmg
*.pkg

# ============================================================================
# 依赖目录
# ============================================================================
node_modules/
vendor/
third_party/
external/

# ============================================================================
# 缓存文件
# ============================================================================
.cache/
__pycache__/
*.pyc
*.pyo
.mypy_cache/
.pytest_cache/

# ============================================================================
# 环境文件
# ============================================================================
.env
.env.local
.env.*.local
.venv/
venv/
ENV/

# ============================================================================
# Docker
# ============================================================================
.dockerignore
Dockerfile
docker-compose.yml
docker-compose.yaml

# ============================================================================
# CI/CD
# ============================================================================
.github/
.gitlab-ci.yml
.travis.yml
.circleci/
Jenkinsfile

# ============================================================================
# 项目特定文件
# ============================================================================
# 配置文件模板
*.conf.example
*.conf.local

# 编译数据库
compile_commands.json

# Meson 构建
builddir/
subprojects/

# CMake 构建
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile.cmake

# Autotools
autom4te.cache/
config.log
config.status
config.h
stamp-h1
libtool
.ltmain.sh

# ============================================================================
# 允许的文件（覆盖上面的规则）
# ============================================================================
# 允许根目录的配置文件
!linuxhud.conf
!linuxhud.service

# 允许文档文件
!*.md
!docs/

# 允许源代码
!src/
!include/
!tests/

# 允许构建脚本
!Makefile
!meson.build
!CMakeLists.txt
!configure.ac
!Makefile.am

# 允许演示和测试脚本
!run_demo.sh
!test_project.sh
